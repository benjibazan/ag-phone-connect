# Antigravity Phone Connect Configuration

# Your password for the mobile interface
# Used to secure your mobile dashboard
APP_PASSWORD=your-app-password

# Your ngrok authtoken (Get a free one from https://dashboard.ngrok.com)
# This prevents the 1-hour session limit and allows stable connections
NGROK_AUTHTOKEN=your-ngrok-authtoken

# AI Provider API Key
# Replace 'xxx' with your provider name (e.g., GROQ_API_KEY, GEMINI_API_KEY)
# xxx_API_KEY=your-xxx-key

# Server Port
PORT=3000

# Antigravity binary path (auto-detected per OS if not set)
# Windows: C:\Users\<user>\AppData\Local\Programs\Antigravity\bin\antigravity.cmd
# macOS:   /Applications/Antigravity.app/Contents/Resources/app/bin/antigravity
# Linux:   antigravity (must be in PATH)
# AG_BIN_PATH=

# Projects root directory (auto-detected per OS if not set)
# Windows default: C:\Proyects
# macOS/Linux default: ~/Projects
# PROJECTS_DIR=
